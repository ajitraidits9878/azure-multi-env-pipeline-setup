# ============================================================
# .gitignore for azure-multi-env-pipeline-setup
# ============================================================

# --------------------------------------------------
# Operating System
# --------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --------------------------------------------------
# IDE & Editor Files
# --------------------------------------------------
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# --------------------------------------------------
# .NET Build Outputs
# --------------------------------------------------
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
*.nupkg
*.snupkg
*.nuspec
project.lock.json
project.fragment.lock.json
artifacts/

# --------------------------------------------------
# Test Results & Coverage
# --------------------------------------------------
TestResults/
coverage/
*.coveragexml
*.opencover.xml
*.cobertura.xml

# --------------------------------------------------
# Azure DevOps Local Run Artifacts
# --------------------------------------------------
.agent/
_work/
*.tar
*.tar.gz

# --------------------------------------------------
# Environment & Secrets
# --------------------------------------------------
.env
.env.*
*.pem
*.pfx
*.p12
*.key
appsettings.*.json
!appsettings.example.json

# --------------------------------------------------
# Docker
# --------------------------------------------------
*.image.tar

# --------------------------------------------------
# Node (for any tooling scripts)
# --------------------------------------------------
node_modules/
npm-debug.log*

# --------------------------------------------------
# Misc
# --------------------------------------------------
*.bak
*.tmp
*.swp
